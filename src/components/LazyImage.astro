---
/**
 * LazyImage — Blur-up lazy loading
 * - Netlify Image CDN for WebP + responsive sizing
 * - Intersection Observer (300px ahead of viewport)
 * - LQIP blur-up: inline SVG placeholder, no layout shift
 */

interface Props {
  src: string;
  alt?: string;
  width?: number;
  class?: string;
  eager?: boolean;
  sizes?: string;
  cover?: boolean; // true = object-fit: cover (for grids)
}

const {
  src,
  alt = '',
  width = 1200,
  class: className = '',
  eager = false,
  sizes = '(max-width: 600px) 100vw, (max-width: 1100px) 50vw, 33vw',
  cover = false,
} = Astro.props;

function netlifyImg(url: string, w: number, q = 80): string {
  if (!url || url.startsWith('data:') || url.startsWith('http')) return url;
  return `/.netlify/images?url=${encodeURIComponent(url)}&w=${w}&fm=webp&q=${q}`;
}

function makeSrcset(url: string): string {
  return [400, 800, 1200, 1600, 2000]
    .map(w => `${netlifyImg(url, w)} ${w}w`)
    .join(', ');
}

const lqip = netlifyImg(src, 40, 20);
const mainSrc = netlifyImg(src, width);
const srcset = makeSrcset(src);
---

<span
  class={`li-wrap ${className}`}
  data-li-wrap
  style={cover ? 'display:block;width:100%;height:100%;' : 'display:block;width:100%;'}
>
  <img
    class="li-img"
    src={lqip}
    data-src={eager ? undefined : mainSrc}
    data-srcset={eager ? undefined : srcset}
    data-sizes={eager ? undefined : sizes}
    srcset={eager ? srcset : undefined}
    sizes={eager ? sizes : undefined}
    alt={alt}
    decoding="async"
    fetchpriority={eager ? 'high' : 'auto'}
    data-eager={eager ? '' : undefined}
    style={cover
      ? 'display:block;width:100%;height:100%;object-fit:cover;'
      : 'display:block;width:100%;height:auto;'}
  />
</span>

<style>
  .li-wrap {
    overflow: hidden;
    background: #eeece9;
    position: relative;
  }

  .li-img {
    filter: blur(0px);
    transition: filter 0.5s ease, opacity 0.4s ease;
  }

  /* While loading: blurred lqip */
  .li-wrap:not(.li-loaded) .li-img {
    filter: blur(8px);
    transform: scale(1.03);
  }

  /* Loaded: sharp */
  .li-wrap.li-loaded .li-img {
    filter: blur(0px);
    transform: scale(1);
    transition: filter 0.5s ease, transform 0.5s ease;
  }
</style>

<script>
  function initLazy() {
    // Handle eager images first
    document.querySelectorAll<HTMLImageElement>('img[data-eager]').forEach(img => {
      const wrap = img.closest('[data-li-wrap]');
      const markLoaded = () => wrap?.classList.add('li-loaded');
      if (img.complete && img.naturalWidth > 0) markLoaded();
      else img.addEventListener('load', markLoaded, { once: true });
    });

    // Lazy images via IntersectionObserver
    const lazyImgs = document.querySelectorAll<HTMLImageElement>('img[data-src]');
    if (!lazyImgs.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const img = entry.target as HTMLImageElement;
        const wrap = img.closest('[data-li-wrap]');

        const src = img.dataset.src;
        const srcset = img.dataset.srcset;
        const sizes = img.dataset.sizes;

        // Swap to full res
        if (srcset) img.srcset = srcset;
        if (sizes) img.sizes = sizes;
        if (src) img.src = src;

        const markLoaded = () => wrap?.classList.add('li-loaded');
        if (img.complete && img.naturalWidth > 0) markLoaded();
        else img.addEventListener('load', markLoaded, { once: true });

        observer.unobserve(img);
      });
    }, { rootMargin: '400px 0px', threshold: 0 });

    lazyImgs.forEach(img => observer.observe(img));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLazy);
  } else {
    initLazy();
  }
</script>
