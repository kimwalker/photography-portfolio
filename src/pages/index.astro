---
import Layout from '../layouts/Layout.astro';
import LazyImage from '../components/LazyImage.astro';
import { getCollection } from 'astro:content';

const allPhotos = await getCollection('photos');
let photos = allPhotos.filter(p => p.data.featured);
if (photos.length === 0) photos = allPhotos;

const photoData = photos.map(p => ({
  image: p.data.image,
  alt: p.data.alt || '',
}));
---

<Layout title="Home" activeNav="home">
  <div class="masonry-grid" id="masonry-grid">
    {photoData.map((photo, i) => (
      <div class="grid-item">
        <LazyImage
          src={photo.image}
          alt={photo.alt}
          eager={i < 6}
          width={1000}
          sizes="(max-width: 600px) 50vw, (max-width: 1100px) 33vw, 25vw"
        />
      </div>
    ))}
  </div>

  {photoData.length === 0 && (
    <div class="empty-state">
      <p>No featured photos yet. Mark some as Featured in the <a href="/admin">CMS</a>.</p>
    </div>
  )}
</Layout>

<style>
  .masonry-grid {
    columns: 4;
    column-gap: 20px;
    padding: 32px 40px 80px;
  }

  .grid-item {
    break-inside: avoid;
    margin-bottom: 20px;
  }

  /* Inset variants — different sizes for variety */
  .grid-item.inset-left {
    width: 78%;
    margin-right: auto;
    margin-left: 0;
  }

  .grid-item.inset-right {
    width: 78%;
    margin-left: auto;
    margin-right: 0;
  }

  .grid-item.inset-small-left {
    width: 58%;
    margin-right: auto;
    margin-left: 0;
  }

  .grid-item.inset-small-right {
    width: 58%;
    margin-left: auto;
    margin-right: 0;
  }

  /* Push down: adds top margin for vertical rhythm variation */
  .grid-item.push-down {
    margin-top: 32px;
  }

  .grid-item:hover .li-wrap {
    opacity: 0.93;
    transition: opacity 0.2s ease;
  }

  .empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    height: calc(100vh - 52px);
    font-size: 13px;
    color: #999;
  }

  .empty-state a {
    color: #111;
    text-decoration: underline;
  }

  @media (max-width: 1100px) {
    .masonry-grid { columns: 3; column-gap: 14px; padding: 24px 28px 60px; }
    .grid-item { margin-bottom: 14px; }
  }

  @media (max-width: 700px) {
    .masonry-grid {
      columns: 2;
      column-gap: 8px;
      padding: 12px 12px 48px;
    }
    .grid-item { margin-bottom: 8px; }
    .grid-item.inset-left,
    .grid-item.inset-right,
    .grid-item.inset-small-left,
    .grid-item.inset-small-right {
      width: 100%;
      margin-left: 0;
      margin-right: 0;
    }
    .grid-item.push-down { margin-top: 0; }
  }
</style>

<script>
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function initMasonry() {
    const grid = document.getElementById('masonry-grid');
    if (!grid) return;
    const items = Array.from(grid.querySelectorAll('.grid-item'));
    if (!items.length) return;

    // Shuffle order
    const shuffled = shuffle(items);
    const classes = ['inset-left', 'inset-right', 'inset-small-left', 'inset-small-right', 'push-down'];

    shuffled.forEach((item, i) => {
      const r = Math.random();
      // ~55% full width, ~15% inset, ~10% small inset each side, ~10% push-down
      if (r < 0.12) item.classList.add('inset-left');
      else if (r < 0.24) item.classList.add('inset-right');
      else if (r < 0.31) item.classList.add('inset-small-left');
      else if (r < 0.38) item.classList.add('inset-small-right');
      else if (r < 0.48) item.classList.add('push-down');
      // else: full width, no extra class

      grid.appendChild(item);
    });
  }

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', initMasonry)
    : initMasonry();
</script>
