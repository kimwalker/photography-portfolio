---
import Layout from '../layouts/Layout.astro';
import LazyImage from '../components/LazyImage.astro';
import { getCollection } from 'astro:content';

const allPhotos = await getCollection('photos');
let photos = allPhotos.filter(p => p.data.featured);
if (photos.length === 0) photos = allPhotos;

const photoData = photos.map(p => ({
  image: p.data.image,
  alt: p.data.alt || '',
}));
---

<Layout title="Home" activeNav="home">
  <div class="masonry-grid" id="masonry-grid">
    {photoData.map((photo, i) => (
      <div class="grid-item">
        <LazyImage
          src={photo.image}
          alt={photo.alt}
          eager={i < 6}
          width={1000}
          sizes="(max-width: 600px) 50vw, (max-width: 1100px) 33vw, 25vw"
        />
      </div>
    ))}
  </div>

  {photoData.length === 0 && (
    <div class="empty-state">
      <p>No featured photos yet. Mark some as Featured in the <a href="/admin">CMS</a>.</p>
    </div>
  )}
</Layout>

<style>
  .masonry-grid {
    columns: 4;
    column-gap: 6px;
    padding: 20px 20px 60px;
  }

  .grid-item {
    break-inside: avoid;
    margin-bottom: 6px;
    /* Size variants assigned by JS */
  }

  /* Wide: full column width (default) */
  /* Inset: reduced width, floated for Tillmans looseness */
  .grid-item.inset-left {
    width: 72%;
    margin-right: auto;
  }

  .grid-item.inset-right {
    width: 72%;
    margin-left: auto;
  }

  .grid-item:hover .li-wrap {
    opacity: 0.93;
    transition: opacity 0.2s ease;
  }

  .empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    height: calc(100vh - 52px);
    font-size: 13px;
    color: #999;
  }

  .empty-state a {
    color: #111;
    text-decoration: underline;
  }

  @media (max-width: 1100px) {
    .masonry-grid { columns: 3; }
  }

  @media (max-width: 700px) {
    .masonry-grid {
      columns: 2;
      column-gap: 4px;
      padding: 12px 12px 48px;
    }
    .grid-item.inset-left,
    .grid-item.inset-right {
      width: 100%;
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>

<script>
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function initMasonry() {
    const grid = document.getElementById('masonry-grid');
    if (!grid) return;
    const items = Array.from(grid.querySelectorAll('.grid-item'));
    if (!items.length) return;

    // Shuffle order
    const shuffled = shuffle(items);
    shuffled.forEach((item, i) => {
      // Assign size variants for Tillmans looseness
      const r = Math.random();
      if (r < 0.15) item.classList.add('inset-left');
      else if (r < 0.30) item.classList.add('inset-right');
      // else: full width (default)
      grid.appendChild(item);
    });
  }

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', initMasonry)
    : initMasonry();
</script>
