---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Photography Portfolio">
  <main style="display:flex; flex-direction:column; align-items:center; justify-content:center; flex:1; min-height:100vh; gap:1rem; padding:2rem; text-align:center;">
    <h1 style="font-size:2rem; font-weight:300; letter-spacing:0.2em; text-transform:uppercase;">
      Coming Soon
    </h1>
