---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Get featured photos. Fallback to all photos if none are featured.
const allPhotos = await getCollection('photos');
let photos = allPhotos.filter(p => p.data.featured);
if (photos.length === 0) photos = allPhotos;

// Serialize for client-side shuffle
const photoData = photos.map(p => ({
  image: p.data.image,
  alt: p.data.alt || '',
  title: p.data.title || '',
}));
---

<Layout title="Home" activeNav="home">
  <div class="masonry-grid" id="masonry-grid">
    {photoData.map((photo, i) => (
      <div class="grid-item" data-index={i}>
        <div class="grid-item-inner">
          <img
            src={photo.image}
            alt={photo.alt}
            loading={i < 8 ? 'eager' : 'lazy'}
            decoding="async"
            onload="this.closest('.grid-item').classList.add('loaded')"
          />
        </div>
      </div>
    ))}
  </div>

  {photoData.length === 0 && (
    <div class="empty-state">
      <p>No photos yet. Add some in the <a href="/admin">CMS</a>.</p>
    </div>
  )}
</Layout>

<style>
  /* ─── MASONRY GRID ──────────────────────────────── */
  .masonry-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 2px;
    gap: 0 6px;
    padding: 20px 20px 60px;
  }

  .grid-item {
    padding-bottom: 6px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .grid-item.loaded,
  .grid-item.visible {
    opacity: 1;
  }

  /* Wide items span 2 columns — assigned randomly by JS */
  .grid-item.wide {
    grid-column: span 2;
  }

  /* Small items — slightly reduced, gives the Tillmans looseness */
  .grid-item.small .grid-item-inner {
    width: 75%;
    /* Alternate left/right alignment for visual rhythm */
  }

  .grid-item.small-left .grid-item-inner {
    width: 72%;
    margin-left: 0;
  }

  .grid-item.small-right .grid-item-inner {
    width: 72%;
    margin-left: auto;
  }

  .grid-item-inner {
    overflow: hidden;
    background: #f0f0f0;
  }

  .grid-item img {
    display: block;
    width: 100%;
    height: auto;
    transition: opacity 0.2s ease;
  }

  /* Hover state — subtle */
  .grid-item:hover img {
    opacity: 0.92;
  }

  /* ─── EMPTY STATE ───────────────────────────────── */
  .empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    height: calc(100vh - 52px);
    font-size: 13px;
    color: #999;
  }

  .empty-state a {
    color: #111;
    text-decoration: underline;
  }

  /* ─── RESPONSIVE ────────────────────────────────── */
  @media (max-width: 1100px) {
    .masonry-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 700px) {
    .masonry-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0 4px;
      padding: 12px 12px 48px;
    }

    .grid-item.wide {
      grid-column: span 2;
    }

    .grid-item.small-left .grid-item-inner,
    .grid-item.small-right .grid-item-inner {
      width: 100%;
    }
  }

  @media (max-width: 400px) {
    .masonry-grid {
      grid-template-columns: 1fr;
    }

    .grid-item.wide {
      grid-column: span 1;
    }
  }
</style>

<script define:vars={{ photoData }}>
  // ─── Fisher-Yates shuffle ────────────────────────
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  // ─── Size class assignment ───────────────────────
  // Gives the Tillmans-esque structured-but-loose feel
  function getSizeClass(index, total) {
    const r = Math.random();
    if (r < 0.12) return 'wide';      // 12% wide (2-col span)
    if (r < 0.24) return 'small-left'; // 12% small-left
    if (r < 0.36) return 'small-right'; // 12% small-right
    return '';                          // 64% standard
  }

  // ─── Masonry row-span calculation ────────────────
  function setRowSpan(item) {
    const inner = item.querySelector('.grid-item-inner');
    if (!inner) return;
    const rowGap = 6;
    const rowHeight = 2;
    const height = inner.getBoundingClientRect().height;
    const span = Math.ceil((height + rowGap) / (rowHeight + rowGap));
    item.style.gridRowEnd = `span ${span}`;
    item.classList.add('visible');
  }

  function initMasonry() {
    const grid = document.getElementById('masonry-grid');
    if (!grid) return;

    const items = Array.from(grid.querySelectorAll('.grid-item'));
    if (items.length === 0) return;

    // Shuffle items in DOM
    const shuffled = shuffle(items);
    shuffled.forEach((item, i) => {
      // Assign size class
      const sizeClass = getSizeClass(i, shuffled.length);
      if (sizeClass) item.classList.add(sizeClass);
      grid.appendChild(item);
    });

    // Calculate row spans after images load
    const imgs = grid.querySelectorAll('img');
    let loadedCount = 0;

    function onImgLoad(img) {
      const item = img.closest('.grid-item');
      if (item) setRowSpan(item);
      loadedCount++;
    }

    imgs.forEach(img => {
      if (img.complete && img.naturalWidth > 0) {
        onImgLoad(img);
      } else {
        img.addEventListener('load', () => onImgLoad(img));
        img.addEventListener('error', () => {
          const item = img.closest('.grid-item');
          if (item) item.style.display = 'none';
        });
      }
    });

    // Recalculate on resize (debounced)
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        grid.querySelectorAll('.grid-item').forEach(item => setRowSpan(item));
      }, 150);
    });
  }

  // Run after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMasonry);
  } else {
    initMasonry();
  }
</script>
