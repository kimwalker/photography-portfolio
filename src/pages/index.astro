---
import Layout from '../layouts/Layout.astro';
import LazyImage from '../components/LazyImage.astro';
import { getCollection } from 'astro:content';

const allPhotos = await getCollection('photos');
let photos = allPhotos.filter(p => p.data.featured);
if (photos.length === 0) photos = allPhotos;

const photoData = photos.map(p => ({
  image: p.data.image,
  alt: p.data.alt || '',
}));
---

<Layout title="Home" activeNav="home">
  <div class="masonry-grid" id="masonry-grid">
    {photoData.map((photo, i) => (
      <div class="grid-item">
        <LazyImage
          src={photo.image}
          alt={photo.alt}
          eager={i < 6}
          width={1000}
          sizes="(max-width: 700px) 92vw, (max-width: 1100px) 33vw, 25vw"
        />
      </div>
    ))}
  </div>

  {photoData.length === 0 && (
    <div class="empty-state">
      <p>No featured photos yet. Mark some as Featured in the <a href="/admin">CMS</a>.</p>
    </div>
  )}
</Layout>

<style>
  /* ── Desktop: 4-col CSS columns masonry ── */
  .masonry-grid {
    columns: 4;
    column-gap: 20px;
    padding: 32px 40px 80px;
  }

  .grid-item {
    break-inside: avoid;
    margin-bottom: 20px;
  }

  .grid-item.inset-left {
    width: 78%;
    margin-right: auto;
    margin-left: 0;
  }

  .grid-item.inset-right {
    width: 78%;
    margin-left: auto;
    margin-right: 0;
  }

  .grid-item.inset-small-left {
    width: 58%;
    margin-right: auto;
    margin-left: 0;
  }

  .grid-item.inset-small-right {
    width: 58%;
    margin-left: auto;
    margin-right: 0;
  }

  .grid-item.push-down {
    margin-top: 32px;
  }

  .grid-item:hover .li {
    opacity: 0.93;
    transition: opacity 0.2s ease;
  }

  .empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    height: calc(100vh - 52px);
    font-size: 13px;
    color: #999;
  }

  .empty-state a { color: #111; text-decoration: underline; }

  @media (max-width: 1100px) {
    .masonry-grid { columns: 3; column-gap: 14px; padding: 24px 28px 60px; }
    .grid-item { margin-bottom: 14px; }
  }

  /* ── Mobile: single column with Tillmans offsets ── */
  @media (max-width: 700px) {
    .masonry-grid {
      columns: 1;
      padding: 20px 20px 48px;
    }

    .grid-item {
      margin-bottom: 0;
      /* reset all desktop widths — JS will assign mobile classes */
      width: 100% !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      margin-top: 0 !important;
    }

    /* Mobile size variants */
    .grid-item.m-full {
      width: 100% !important;
      margin-bottom: 16px;
    }

    .grid-item.m-right {
      width: 88% !important;
      margin-left: auto !important;
      margin-right: 0 !important;
      margin-bottom: 16px;
    }

    .grid-item.m-left {
      width: 88% !important;
      margin-left: 0 !important;
      margin-right: auto !important;
      margin-bottom: 16px;
    }

    .grid-item.m-inset-right {
      width: 72% !important;
      margin-left: auto !important;
      margin-right: 0 !important;
      margin-bottom: 16px;
    }

    .grid-item.m-inset-left {
      width: 72% !important;
      margin-left: 0 !important;
      margin-right: auto !important;
      margin-bottom: 16px;
    }

    .grid-item.m-gap-top {
      margin-top: 28px !important;
    }
  }
</style>

<script>
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  const MOBILE_BP = 700;
  const desktopClasses = ['inset-left','inset-right','inset-small-left','inset-small-right','push-down'];
  const mobileClasses  = ['m-full','m-right','m-left','m-inset-right','m-inset-left','m-gap-top'];

  function clearVariantClasses(item) {
    item.classList.remove(...desktopClasses, ...mobileClasses);
  }

  function applyDesktopVariants(items) {
    items.forEach(item => {
      clearVariantClasses(item);
      const r = Math.random();
      if      (r < 0.12) item.classList.add('inset-left');
      else if (r < 0.24) item.classList.add('inset-right');
      else if (r < 0.31) item.classList.add('inset-small-left');
      else if (r < 0.38) item.classList.add('inset-small-right');
      else if (r < 0.48) item.classList.add('push-down');
    });
  }

  function applyMobileVariants(items) {
    // Single column — vary width and alignment
    // Avoid two consecutive insets of the same side
    let lastClass = '';
    items.forEach((item, i) => {
      clearVariantClasses(item);
      const r = Math.random();
      let cls = 'm-full';

      if (r < 0.30) {
        // Alternate sides to avoid clustering
        cls = lastClass === 'm-right' ? 'm-left' : 'm-right';
      } else if (r < 0.46) {
        cls = lastClass === 'm-inset-right' ? 'm-inset-left' : 'm-inset-right';
      } else {
        cls = 'm-full';
      }

      item.classList.add(cls);
      lastClass = cls;

      // Occasionally add extra top gap for rhythm (~20% chance)
      if (Math.random() < 0.20) item.classList.add('m-gap-top');
    });
  }

  function initMasonry() {
    const grid = document.getElementById('masonry-grid');
    if (!grid) return;
    const items = Array.from(grid.querySelectorAll('.grid-item'));
    if (!items.length) return;

    const isMobile = window.innerWidth <= MOBILE_BP;

    // Shuffle order
    const shuffled = shuffle(items);
    shuffled.forEach(item => grid.appendChild(item));

    // Apply appropriate variants
    if (isMobile) {
      applyMobileVariants(shuffled);
    } else {
      applyDesktopVariants(shuffled);
    }
  }

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', initMasonry)
    : initMasonry();
</script>
