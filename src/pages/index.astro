---
import Layout from '../layouts/Layout.astro';
import LazyImage from '../components/LazyImage.astro';
import { getCollection } from 'astro:content';

const allPhotos = await getCollection('photos');
let photos = allPhotos.filter(p => p.data.featured);
if (photos.length === 0) photos = allPhotos;

const photoData = photos.map(p => ({
  image: p.data.image,
  alt: p.data.alt || '',
}));
---

<Layout title="Home" activeNav="home">
  <div class="masonry-grid" id="masonry-grid">
    {photoData.map((photo, i) => (
      <div class="grid-item" data-index={i}>
        <div class="grid-item-inner">
          <LazyImage
            src={photo.image}
            alt={photo.alt}
            eager={i < 6}
            width={1000}
            sizes="(max-width: 600px) 50vw, (max-width: 1100px) 33vw, 25vw"
          />
        </div>
      </div>
    ))}
  </div>

  {photoData.length === 0 && (
    <div class="empty-state">
      <p>No photos yet. Add some in the <a href="/admin">CMS</a>.</p>
    </div>
  )}
</Layout>

<style>
  .masonry-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 2px;
    gap: 0 6px;
    padding: 20px 20px 60px;
  }

  .grid-item {
    padding-bottom: 6px;
  }

  .grid-item.wide { grid-column: span 2; }

  .grid-item.small-left .grid-item-inner {
    width: 72%;
    margin-left: 0;
  }

  .grid-item.small-right .grid-item-inner {
    width: 72%;
    margin-left: auto;
  }

  .grid-item-inner { overflow: hidden; }

  .grid-item:hover .lazy-wrap {
    opacity: 0.92;
    transition: opacity 0.2s ease;
  }

  .empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    height: calc(100vh - 52px);
    font-size: 13px;
    color: #999;
  }

  .empty-state a { color: #111; text-decoration: underline; }

  @media (max-width: 1100px) {
    .masonry-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 700px) {
    .masonry-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0 4px;
      padding: 12px 12px 48px;
    }
    .grid-item.small-left .grid-item-inner,
    .grid-item.small-right .grid-item-inner { width: 100%; }
  }
</style>

<script define:vars={{ photoData }}>
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function setRowSpan(item) {
    const inner = item.querySelector('.grid-item-inner');
    if (!inner) return;
    const height = inner.getBoundingClientRect().height;
    if (height === 0) return;
    const span = Math.ceil((height + 6) / (2 + 6));
    item.style.gridRowEnd = `span ${span}`;
  }

  function initMasonry() {
    const grid = document.getElementById('masonry-grid');
    if (!grid) return;
    const items = Array.from(grid.querySelectorAll('.grid-item'));
    if (!items.length) return;

    shuffle(items).forEach((item) => {
      const r = Math.random();
      if (r < 0.12) item.classList.add('wide');
      else if (r < 0.24) item.classList.add('small-left');
      else if (r < 0.36) item.classList.add('small-right');
      grid.appendChild(item);
    });

    // Recalc spans as images load
    grid.querySelectorAll('img').forEach(img => {
      const item = img.closest('.grid-item');
      if (!item) return;
      if (img.complete && img.naturalWidth > 0) {
        setRowSpan(item);
      } else {
        img.addEventListener('load', () => setRowSpan(item));
      }
    });

    // Also watch for lazy-wrap class changes (blur-up completion)
    const mo = new MutationObserver(() => {
      grid.querySelectorAll('.grid-item').forEach(setRowSpan);
    });
    grid.querySelectorAll('.lazy-wrap').forEach(wrap => {
      mo.observe(wrap, { attributes: true, attributeFilter: ['class'] });
    });

    let t;
    window.addEventListener('resize', () => {
      clearTimeout(t);
      t = setTimeout(() => grid.querySelectorAll('.grid-item').forEach(setRowSpan), 150);
    });
  }

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', initMasonry)
    : initMasonry();
</script>
