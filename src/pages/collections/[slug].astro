---
import Layout from '../../layouts/Layout.astro';
import LazyImage from '../../components/LazyImage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allGalleries = await getCollection('galleries', ({ data }) => data.published);

  return allGalleries.map((gallery, index) => ({
    params: { slug: gallery.data.slug },
    props: {
      gallery,
      prevGallery: index > 0 ? allGalleries[index - 1] : null,
      nextGallery: index < allGalleries.length - 1 ? allGalleries[index + 1] : null,
    },
  }));
}

const { gallery, prevGallery, nextGallery } = Astro.props;

const allPhotos = await getCollection('photos');
const galleryPhotos = allPhotos.filter(p =>
  Array.isArray(p.data.collections) && p.data.collections.includes(gallery.data.slug)
);
---

<Layout
  title={gallery.data.title}
  navCenter={gallery.data.title}
  activeNav="collections"
>
  <div class="collection-page">

    <header class="collection-header">
      {gallery.data.description && (
        <p class="collection-description">{gallery.data.description}</p>
      )}
    </header>

    <div class="image-feed">
      {galleryPhotos.map((photo, i) => (
        <div class="feed-item">
          <LazyImage
            src={photo.data.image}
            alt={photo.data.alt || ''}
            eager={i < 2}
            sizes="(max-width: 700px) 95vw, 860px"
          />
        </div>
      ))}
    </div>

    {galleryPhotos.length === 0 && (
      <div class="no-photos">
        <p>No photos tagged to <strong>{gallery.data.slug}</strong> yet.</p>
      </div>
    )}

    <nav class="collection-nav">
      <div class="collection-nav-inner">
        {prevGallery ? (
          <a href={`/collections/${prevGallery.data.slug}`} class="collection-nav-link prev">
            <span class="nav-dir">← Previous</span>
            <span class="nav-title">{prevGallery.data.title}</span>
          </a>
        ) : <div />}

        <a href="/collections" class="collection-nav-all">All Collections</a>

        {nextGallery ? (
          <a href={`/collections/${nextGallery.data.slug}`} class="collection-nav-link next">
            <span class="nav-dir">Next →</span>
            <span class="nav-title">{nextGallery.data.title}</span>
          </a>
        ) : <div />}
      </div>
    </nav>

  </div>
</Layout>

<style>
  .collection-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px 80px;
  }

  .collection-header {
    padding: 48px 0 40px;
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .collection-description {
    font-family: var(--font);
    font-size: 15px;
    line-height: 1.75;
    color: #333;
  }

  .image-feed {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .feed-item {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .feed-item .li { width: 100%; }
  .feed-item.portrait .li { width: 60%; }

  .no-photos {
    padding: 60px 20px;
    text-align: center;
    color: #999;
    font-size: 13px;
  }

  .collection-nav {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .collection-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  .collection-nav-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .collection-nav-link.next { text-align: right; }
  .nav-dir { font-size: 11px; letter-spacing: 0.06em; color: #999; }
  .nav-title { font-size: 13px; color: #111; transition: opacity 0.15s ease; }
  .collection-nav-link:hover .nav-title { opacity: 0.6; }
  .collection-nav-all {
    font-size: 12px; letter-spacing: 0.06em; text-decoration: none;
    color: #999; white-space: nowrap; transition: color 0.15s ease;
  }
  .collection-nav-all:hover { color: #111; }

  @media (max-width: 700px) {
    .feed-item.portrait .li { width: 80%; }
    .collection-nav-inner { grid-template-columns: 1fr; gap: 16px; }
    .collection-nav-link.next { text-align: left; }
    .collection-nav-all { order: -1; }
  }
</style>

<script>
  document.querySelectorAll('.feed-item').forEach(item => {
    const img = item.querySelector('img');
    if (!img) return;
    const check = () => {
      if (img.naturalWidth > 0 && img.naturalHeight > img.naturalWidth) {
        item.classList.add('portrait');
      }
    };
    img.complete ? check() : img.addEventListener('load', check, { once: true });
  });
</script>
