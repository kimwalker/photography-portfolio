---
import Layout from '../../layouts/Layout.astro';
import LazyImage from '../../components/LazyImage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allGalleries = await getCollection('galleries', ({ data }) => data.published);

  return allGalleries.map((gallery, index) => ({
    params: { slug: gallery.data.slug },
    props: {
      gallery,
      prevGallery: index > 0 ? allGalleries[index - 1] : null,
      nextGallery: index < allGalleries.length - 1 ? allGalleries[index + 1] : null,
    },
  }));
}

const { gallery, prevGallery, nextGallery } = Astro.props;

const allPhotos = await getCollection('photos');
const photosByTitle = Object.fromEntries(
  allPhotos.map(p => [p.data.title?.toLowerCase().trim(), p])
);

type SingleRow = { type: 'single'; photo: typeof allPhotos[0] };
type PairRow   = { type: 'pair';   photos: [typeof allPhotos[0], typeof allPhotos[0]] };
type Row = SingleRow | PairRow;

const sequence = gallery.data.photoSequence ?? [];
const rows: Row[] = [];
let i = 0;

while (i < sequence.length) {
  const entry = sequence[i];
  const photo = photosByTitle[entry.photo.toLowerCase().trim()];
  if (!photo) { i++; continue; }

  if (entry.layout === 'pair' && i + 1 < sequence.length) {
    const nextEntry = sequence[i + 1];
    const nextPhoto = photosByTitle[nextEntry.photo.toLowerCase().trim()];
    if (nextPhoto && nextEntry.layout === 'pair') {
      rows.push({ type: 'pair', photos: [photo, nextPhoto] });
      i += 2;
      continue;
    }
  }

  rows.push({ type: 'single', photo });
  i++;
}

const hasSequence = sequence.length > 0;
---

<Layout
  title={gallery.data.title}
  navCenter={gallery.data.title}
  activeNav="collections"
>
  <div class="collection-page">

    {gallery.data.description && (
      <header class="collection-header">
        <p class="collection-description">{gallery.data.description}</p>
      </header>
    )}

    <div class="image-feed">
      {hasSequence ? rows.map(row => (
        row.type === 'single' ? (
          <div class="feed-single">
            <div class="feed-img-wrap" data-detect-orientation>
              <LazyImage
                src={row.photo.data.image}
                alt={row.photo.data.alt || ''}
                sizes="(max-width: 700px) 95vw, 860px"
              />
            </div>
          </div>
        ) : (
          <div class="feed-pair">
            <div class="feed-pair-img">
              <LazyImage
                src={row.photos[0].data.image}
                alt={row.photos[0].data.alt || ''}
                sizes="(max-width: 700px) 50vw, 430px"
              />
            </div>
            <div class="feed-pair-img">
              <LazyImage
                src={row.photos[1].data.image}
                alt={row.photos[1].data.alt || ''}
                sizes="(max-width: 700px) 50vw, 430px"
              />
            </div>
          </div>
        )
      )) : (
        <div class="no-photos">
          <p>Add photos to this collection using the Photo Sequence in the CMS.</p>
        </div>
      )}
    </div>

    <nav class="collection-nav">
      <div class="collection-nav-inner">
        {prevGallery ? (
          <a href={`/collections/${prevGallery.data.slug}`} class="collection-nav-link prev">
            <span class="nav-dir">← Previous</span>
            <span class="nav-name">{prevGallery.data.title}</span>
          </a>
        ) : <div />}

        <a href="/collections" class="collection-nav-all">All Collections</a>

        {nextGallery ? (
          <a href={`/collections/${nextGallery.data.slug}`} class="collection-nav-link next">
            <span class="nav-dir">Next →</span>
            <span class="nav-name">{nextGallery.data.title}</span>
          </a>
        ) : <div />}
      </div>
    </nav>

  </div>
</Layout>

<style>
  .collection-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 20px 20px 80px;
  }

  .collection-header {
    padding: 48px 0 40px;
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .collection-description {
    font-size: 14px;
    line-height: 1.8;
    color: #444;
  }

  .image-feed {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .feed-single {
    display: flex;
    justify-content: center;
  }

  .feed-img-wrap { width: 100%; }
  .feed-img-wrap.is-portrait { width: 60%; }

  .feed-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    align-items: start;
  }

  .feed-pair-img {
    overflow: hidden;
  }

  .feed-pair-img .li {
    width: 100%;
  }

  .no-photos {
    padding: 60px 20px;
    text-align: center;
    color: #999;
    font-size: 13px;
  }

  .collection-nav {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .collection-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  .collection-nav-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .collection-nav-link.next { text-align: right; }
  .nav-dir { font-size: 11px; letter-spacing: 0.06em; color: #999; }
  .nav-name { font-size: 13px; color: #111; transition: opacity 0.15s ease; }
  .collection-nav-link:hover .nav-name { opacity: 0.6; }

  .collection-nav-all {
    font-size: 12px; letter-spacing: 0.06em; text-decoration: none;
    color: #999; white-space: nowrap; transition: color 0.15s ease;
  }
  .collection-nav-all:hover { color: #111; }

  @media (max-width: 700px) {
    .feed-img-wrap.is-portrait { width: 80%; }
    .collection-nav-inner { grid-template-columns: 1fr; gap: 16px; }
    .collection-nav-link.next { text-align: left; }
    .collection-nav-all { order: -1; }
  }
</style>

<script>
  document.querySelectorAll('[data-detect-orientation]').forEach(wrap => {
    const img = wrap.querySelector('img');
    if (!img) return;
    const check = () => {
      if (img.naturalWidth > 0 && img.naturalHeight > img.naturalWidth) {
        wrap.classList.add('is-portrait');
      }
    };
    (img as HTMLImageElement).complete ? check() : img.addEventListener('load', check, { once: true });
  });
</script>
