---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import LazyImage from '../../components/LazyImage.astro';

export async function getStaticPaths() {
  const galleries = await getCollection('galleries', ({ data }) => data.published);

  return galleries.map((gallery, index) => ({
    params: { slug: gallery.data.slug },
    props: {
      gallery,
      prevGallery: index > 0 ? galleries[index - 1] : null,
      nextGallery: index < galleries.length - 1 ? galleries[index + 1] : null,
    },
  }));
}

const { gallery, prevGallery, nextGallery } = Astro.props;

// Get all photos belonging to this collection
const allPhotos = await getCollection('photos');
const galleryPhotos = allPhotos.filter(p =>
  p.data.collections.some(col => col.slug === gallery.data.slug)
);
---

<Layout
  title={gallery.data.title}
  navCenter={gallery.data.title}
  activeNav="collections"
>
  <div class="collection-page">

    <header class="collection-header">
      {gallery.data.description && (
        <p class="collection-description">{gallery.data.description}</p>
      )}
    </header>

    <div class="image-feed">
      {galleryPhotos.map((photo, i) => (
        <div class="feed-item" data-image={photo.data.image}>
          <LazyImage
            src={photo.data.image}
            alt={photo.data.alt || photo.data.title || ''}
            eager={i < 2}
            width={1400}
            sizes="(max-width: 700px) 90vw, 900px"
            class="feed-image"
          />
        </div>
      ))}
    </div>

    {galleryPhotos.length === 0 && (
      <div class="no-photos">
        <p>No photos in this collection yet. Tag photos to <strong>{gallery.data.slug}</strong> in the CMS.</p>
      </div>
    )}

    {galleryPhotos.length > 1 && (
      <div class="bottom-grid-section">
        <p class="bottom-grid-label">All images</p>
        <div class="bottom-grid">
          {galleryPhotos.map((photo) => (
            <div class="bottom-grid-item">
              <LazyImage src={photo.data.image} alt={photo.data.alt || ''} width={400} sizes="25vw" objectFit="cover" />
            </div>
          ))}
        </div>
      </div>
    )}

    <nav class="collection-nav">
      <div class="collection-nav-inner">
        {prevGallery ? (
          <a href={`/collections/${prevGallery.data.slug}`} class="collection-nav-link prev">
            <span class="nav-dir">← Previous</span>
            <span class="nav-title">{prevGallery.data.title}</span>
          </a>
        ) : <div />}

        <a href="/collections" class="collection-nav-all">All Collections</a>

        {nextGallery ? (
          <a href={`/collections/${nextGallery.data.slug}`} class="collection-nav-link next">
            <span class="nav-dir">Next →</span>
            <span class="nav-title">{nextGallery.data.title}</span>
          </a>
        ) : <div />}
      </div>
    </nav>

  </div>
</Layout>

<style>
  /* Reuses same patterns as project detail */
  .collection-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px 80px;
  }

  .collection-header {
    padding: 48px 0 40px;
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .collection-description {
    font-family: var(--font-serif, 'DM Serif Text', Georgia, serif);
    font-size: 15px;
    line-height: 1.75;
    color: #333;
  }

  .image-feed {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .feed-item {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .feed-image {
    display: block;
    max-width: 100%;
    height: auto;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .feed-image.loaded { opacity: 1; }

  .feed-item[data-orientation="portrait"] .feed-image {
    max-width: 60%;
  }

  .no-photos {
    padding: 60px 20px;
    text-align: center;
    color: #999;
    font-size: 13px;
  }

  .bottom-grid-section {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .bottom-grid-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 16px;
  }

  .bottom-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
  }

  .bottom-grid-item {
    aspect-ratio: 1;
    overflow: hidden;
    background: #f0f0f0;
  }

  .bottom-grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .collection-nav {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .collection-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  .collection-nav-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .collection-nav-link.next { text-align: right; }

  .nav-dir {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #999;
  }

  .nav-title {
    font-size: 13px;
    color: #111;
    transition: opacity 0.15s ease;
  }

  .collection-nav-link:hover .nav-title { opacity: 0.6; }

  .collection-nav-all {
    font-size: 12px;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: #999;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .collection-nav-all:hover { color: #111; }

  @media (max-width: 700px) {
    .bottom-grid { grid-template-columns: repeat(3, 1fr); }
    .feed-item[data-orientation="portrait"] .feed-image { max-width: 80%; }
    .collection-nav-inner { grid-template-columns: 1fr; gap: 16px; }
    .collection-nav-link.next { text-align: left; }
    .collection-nav-all { order: -1; }
  }
</style>

<script>
  document.querySelectorAll('.feed-item').forEach(item => {
    const img = item.querySelector('.feed-image') as HTMLImageElement;
    if (!img) return;

    function applyOrientation() {
      if (img.naturalWidth > 0 && img.naturalHeight > 0) {
        item.setAttribute('data-orientation',
          img.naturalHeight > img.naturalWidth ? 'portrait' : 'landscape'
        );
        img.classList.add('loaded');
      }
    }

    img.complete ? applyOrientation() : img.addEventListener('load', applyOrientation);
  });
</script>
