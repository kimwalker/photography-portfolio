---
import Layout from '../../layouts/Layout.astro';
import LazyImage from '../../components/LazyImage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects', ({ data }) => data.published);
  const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((project, index) => ({
    params: { slug: project.data.slug },
    props: {
      project,
      prevProject: index > 0 ? sorted[index - 1] : null,
      nextProject: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { project, prevProject, nextProject } = Astro.props;

// Build a lookup of all photos by title
const allPhotos = await getCollection('photos');
const photosByTitle = Object.fromEntries(
  allPhotos.map(p => [p.data.title?.toLowerCase().trim(), p])
);

// Resolve the photo sequence into ordered, typed rows
type SingleRow = { type: 'single'; photo: typeof allPhotos[0] };
type PairRow   = { type: 'pair';   photos: [typeof allPhotos[0], typeof allPhotos[0]] };
type Row = SingleRow | PairRow;

const sequence = project.data.photoSequence ?? [];
const rows: Row[] = [];
let i = 0;

while (i < sequence.length) {
  const entry = sequence[i];
  const photo = photosByTitle[entry.photo.toLowerCase().trim()];
  if (!photo) { i++; continue; } // skip if photo not found

  if (entry.layout === 'pair' && i + 1 < sequence.length) {
    const nextEntry = sequence[i + 1];
    const nextPhoto = photosByTitle[nextEntry.photo.toLowerCase().trim()];
    if (nextPhoto && nextEntry.layout === 'pair') {
      rows.push({ type: 'pair', photos: [photo, nextPhoto] });
      i += 2;
      continue;
    }
  }

  rows.push({ type: 'single', photo });
  i++;
}

// Fallback: if no sequence defined, show all tagged photos
const hasSequence = sequence.length > 0;
const fallbackPhotos = hasSequence ? [] : allPhotos.filter(p =>
  Array.isArray(p.data.projects) && p.data.projects?.includes(project.data.slug)
);

// All photos for the bottom grid
const allProjectPhotos = hasSequence
  ? rows.flatMap(r => r.type === 'pair' ? r.photos : [r.photo])
  : fallbackPhotos;
---

<Layout
  title={project.data.title}
  navCenter={project.data.title}
  navCenterSub={project.data.date}
  activeNav="projects"
>
  <div class="project-page">

    {project.data.description && (
      <header class="project-header">
        <p class="project-description">{project.data.description}</p>
      </header>
    )}

    <div class="image-feed">
      {hasSequence ? rows.map(row => (
        row.type === 'single' ? (
          <div class="feed-single">
            <div class="feed-img-wrap" data-detect-orientation>
              <LazyImage
                src={row.photo.data.image}
                alt={row.photo.data.alt || ''}
                sizes="(max-width: 700px) 95vw, 860px"
              />
            </div>
          </div>
        ) : (
          <div class="feed-pair">
            <div class="feed-pair-img">
              <LazyImage
                src={row.photos[0].data.image}
                alt={row.photos[0].data.alt || ''}
                sizes="(max-width: 700px) 50vw, 430px"
              />
            </div>
            <div class="feed-pair-img">
              <LazyImage
                src={row.photos[1].data.image}
                alt={row.photos[1].data.alt || ''}
                sizes="(max-width: 700px) 50vw, 430px"
              />
            </div>
          </div>
        )
      )) : fallbackPhotos.length > 0 ? fallbackPhotos.map((photo, idx) => (
        <div class="feed-single">
          <div class="feed-img-wrap" data-detect-orientation>
            <LazyImage
              src={photo.data.image}
              alt={photo.data.alt || ''}
              eager={idx < 2}
              sizes="(max-width: 700px) 95vw, 860px"
            />
          </div>
        </div>
      )) : (
        <div class="no-photos">
          <p>Add photos to this project using the Photo Sequence in the CMS.</p>
        </div>
      )}
    </div>

    {allProjectPhotos.length > 1 && (
      <div class="bottom-grid-section">
        <p class="bottom-grid-label">All images</p>
        <div class="bottom-grid">
          {allProjectPhotos.map(photo => (
            <div class="bottom-grid-item">
              <LazyImage
                src={photo.data.image}
                alt={photo.data.alt || ''}
                sizes="(max-width: 700px) 33vw, 220px"
              />
            </div>
          ))}
        </div>
      </div>
    )}

    <nav class="project-nav">
      <div class="project-nav-inner">
        {prevProject ? (
          <a href={`/projects/${prevProject.data.slug}`} class="project-nav-link prev">
            <span class="nav-dir">← Previous</span>
            <span class="nav-name">{prevProject.data.title}</span>
          </a>
        ) : <div />}

        <a href="/projects" class="project-nav-all">All Projects</a>

        {nextProject ? (
          <a href={`/projects/${nextProject.data.slug}`} class="project-nav-link next">
            <span class="nav-dir">Next →</span>
            <span class="nav-name">{nextProject.data.title}</span>
          </a>
        ) : <div />}
      </div>
    </nav>

  </div>
</Layout>

<style>
  .project-page {
    max-width: 70vw;
    margin: 0 auto;
    padding: 20px 0 80px;
  }

  /* ── Header ─────────────────────────────────── */
  .project-header {
    padding: 48px 0 40px;
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .project-description {
    font-size: 14px;
    line-height: 1.8;
    color: #444;
  }

  /* ── Feed ───────────────────────────────────── */
  .image-feed {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Single image row */
  .feed-single {
    display: flex;
    justify-content: center;
  }

  .feed-img-wrap {
    width: 100%;
  }

  /* Portrait: constrained to 60% width */
  .feed-img-wrap.is-portrait {
    width: 60%;
  }

  /* Pair row: two images side by side, same height */
  .feed-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .feed-pair-img {
    overflow: hidden;
  }

  .feed-pair-img .li {
    width: 100%;
  }

  /* ── No photos ──────────────────────────────── */
  .no-photos {
    padding: 60px 20px;
    text-align: center;
    color: #999;
    font-size: 13px;
    line-height: 2;
  }

  /* ── Bottom grid ────────────────────────────── */
  .bottom-grid-section {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .bottom-grid-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 16px;
  }

  .bottom-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    align-items: start; /* natural height, no stretch */
  }

  .bottom-grid-item .li {
    width: 100%;
  }

  /* ── Project nav ────────────────────────────── */
  .project-nav {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .project-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  .project-nav-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .project-nav-link.next { text-align: right; }

  .nav-dir {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #999;
  }

  .nav-name {
    font-size: 13px;
    color: #111;
    transition: opacity 0.15s ease;
  }

  .project-nav-link:hover .nav-name { opacity: 0.6; }

  .project-nav-all {
    font-size: 12px;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: #999;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .project-nav-all:hover { color: #111; }

  @media (max-width: 700px) {
    .project-page,
    .collection-page {
      max-width: 100%;
      padding: 16px 16px 60px;
    }

    .feed-pair {
      gap: 10px;
    }

    .bottom-grid { grid-template-columns: repeat(3, 1fr); }
    .feed-img-wrap.is-portrait { width: 80%; }
    .project-nav-inner,
    .collection-nav-inner { grid-template-columns: 1fr; gap: 16px; }
    .project-nav-link.next,
    .collection-nav-link.next { text-align: left; }
    .project-nav-all,
    .collection-nav-all { order: -1; }
  }
</style>

<script>
  // Detect portrait images in single-column feed and constrain width
  document.querySelectorAll('[data-detect-orientation]').forEach(wrap => {
    const img = wrap.querySelector('img');
    if (!img) return;
    const check = () => {
      if (img.naturalWidth > 0 && img.naturalHeight > img.naturalWidth) {
        wrap.classList.add('is-portrait');
      }
    };
    (img as HTMLImageElement).complete ? check() : img.addEventListener('load', check, { once: true });
  });
</script>
