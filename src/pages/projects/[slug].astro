---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.published);
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((project, index) => ({
    params: { slug: project.data.slug },
    props: {
      project,
      prevProject: index > 0 ? sorted[index - 1] : null,
      nextProject: index < sorted.length - 1 ? sorted[index + 1] : null,
      totalProjects: sorted.length,
      projectIndex: index,
    },
  }));
}

const { project, prevProject, nextProject } = Astro.props;

// Get all photos belonging to this project
const allPhotos = await getCollection('photos');
const projectPhotos = allPhotos.filter(p =>
  p.data.projects.some(proj => proj.slug === project.data.slug)
);

// Sort by date if available, otherwise keep CMS order
projectPhotos.sort((a, b) => {
  if (a.data.date && b.data.date) {
    return new Date(a.data.date).getTime() - new Date(b.data.date).getTime();
  }
  return 0;
});
---

<Layout
  title={project.data.title}
  navCenter={project.data.title}
  navCenterSub={project.data.date}
  activeNav="projects"
>
  <div class="project-page">

    <!-- Project header -->
    <header class="project-header">
      {project.data.description && (
        <p class="project-description">{project.data.description}</p>
      )}
    </header>

    <!-- Single column image feed -->
    <div class="image-feed">
      {projectPhotos.map((photo, i) => (
        <div class="feed-item" data-image={photo.data.image}>
          <img
            src={photo.data.image}
            alt={photo.data.alt || photo.data.title || ''}
            loading={i < 2 ? 'eager' : 'lazy'}
            decoding="async"
            class="feed-image"
          />
        </div>
      ))}
    </div>

    {projectPhotos.length === 0 && (
      <div class="no-photos">
        <p>No photos in this project yet. Tag photos to <strong>{project.data.slug}</strong> in the CMS.</p>
      </div>
    )}

    <!-- Bottom image grid (all photos in project) -->
    {projectPhotos.length > 1 && (
      <div class="bottom-grid-section">
        <p class="bottom-grid-label">All images</p>
        <div class="bottom-grid">
          {projectPhotos.map((photo, i) => (
            <div class="bottom-grid-item">
              <img
                src={photo.data.image}
                alt={photo.data.alt || ''}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Project navigation -->
    <nav class="project-nav">
      <div class="project-nav-inner">
        {prevProject ? (
          <a href={`/projects/${prevProject.data.slug}`} class="project-nav-link prev">
            <span class="nav-dir">← Previous</span>
            <span class="nav-title">{prevProject.data.title}</span>
          </a>
        ) : <div />}

        <a href="/projects" class="project-nav-all">All Projects</a>

        {nextProject ? (
          <a href={`/projects/${nextProject.data.slug}`} class="project-nav-link next">
            <span class="nav-dir">Next →</span>
            <span class="nav-title">{nextProject.data.title}</span>
          </a>
        ) : <div />}
      </div>
    </nav>

  </div>
</Layout>

<style>
  .project-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px 80px;
  }

  /* ─── HEADER ────────────────────────────────────── */
  .project-header {
    padding: 48px 0 40px;
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .project-description {
    font-family: var(--font-serif, 'DM Serif Text', Georgia, serif);
    font-size: 15px;
    line-height: 1.75;
    color: #333;
  }

  /* ─── IMAGE FEED ────────────────────────────────── */
  .image-feed {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .feed-item {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .feed-image {
    display: block;
    max-width: 100%;
    height: auto;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .feed-image.loaded {
    opacity: 1;
  }

  /* ─── Portrait vs Landscape handling ────────────
     Portrait images (taller than wide) are constrained
     to 60% width so they don't feel disproportionate.
     Landscape images fill the full column width.
  ──────────────────────────────────────────────── */
  .feed-item[data-orientation="portrait"] .feed-image {
    max-width: 60%;
  }

  /* ─── NO PHOTOS ─────────────────────────────────── */
  .no-photos {
    padding: 60px 20px;
    text-align: center;
    color: #999;
    font-size: 13px;
  }

  /* ─── BOTTOM GRID ───────────────────────────────── */
  .bottom-grid-section {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .bottom-grid-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 16px;
  }

  .bottom-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
  }

  .bottom-grid-item {
    aspect-ratio: 1;
    overflow: hidden;
    background: #f0f0f0;
  }

  .bottom-grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
  }

  .bottom-grid-item:hover img {
    opacity: 0.85;
  }

  /* ─── PROJECT NAV ───────────────────────────────── */
  .project-nav {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .project-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  .project-nav-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .project-nav-link.next {
    text-align: right;
  }

  .nav-dir {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #999;
  }

  .nav-title {
    font-size: 13px;
    color: #111;
    transition: opacity 0.15s ease;
  }

  .project-nav-link:hover .nav-title {
    opacity: 0.6;
  }

  .project-nav-all {
    font-size: 12px;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: #999;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .project-nav-all:hover {
    color: #111;
  }

  /* ─── RESPONSIVE ────────────────────────────────── */
  @media (max-width: 700px) {
    .bottom-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .feed-item[data-orientation="portrait"] .feed-image {
      max-width: 80%;
    }

    .project-nav-inner {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .project-nav-link.next {
      text-align: left;
    }

    .project-nav-all {
      order: -1;
    }
  }
</style>

<script>
  // ─── Detect portrait vs landscape images ────────────────────
  // and apply constrained width to portrait images
  document.querySelectorAll('.feed-item').forEach(item => {
    const img = item.querySelector('.feed-image') as HTMLImageElement;
    if (!img) return;

    function applyOrientation() {
      if (img.naturalWidth > 0 && img.naturalHeight > 0) {
        if (img.naturalHeight > img.naturalWidth) {
          item.setAttribute('data-orientation', 'portrait');
        } else {
          item.setAttribute('data-orientation', 'landscape');
        }
        img.classList.add('loaded');
      }
    }

    if (img.complete) {
      applyOrientation();
    } else {
      img.addEventListener('load', applyOrientation);
    }
  });
</script>
