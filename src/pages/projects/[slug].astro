---
import Layout from '../../layouts/Layout.astro';
import LazyImage from '../../components/LazyImage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects', ({ data }) => data.published);
  const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((project, index) => ({
    params: { slug: project.data.slug },
    props: {
      project,
      prevProject: index > 0 ? sorted[index - 1] : null,
      nextProject: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { project, prevProject, nextProject } = Astro.props;

const allPhotos = await getCollection('photos');
const projectPhotos = allPhotos.filter(p =>
  Array.isArray(p.data.projects) && p.data.projects.includes(project.data.slug)
);
---

<Layout
  title={project.data.title}
  navCenter={project.data.title}
  navCenterSub={project.data.date}
  activeNav="projects"
>
  <div class="project-page">

    <header class="project-header">
      {project.data.description && (
        <p class="project-description">{project.data.description}</p>
      )}
    </header>

    <div class="image-feed">
      {projectPhotos.map((photo, i) => (
        <div class="feed-item">
          <LazyImage
            src={photo.data.image}
            alt={photo.data.alt || ''}
            eager={i < 2}
            sizes="(max-width: 700px) 95vw, 860px"
          />
        </div>
      ))}
    </div>

    {projectPhotos.length === 0 && (
      <div class="no-photos">
        <p>No photos tagged to <strong>{project.data.slug}</strong> yet.</p>
        <p>In the CMS, open a photo and add <strong>{project.data.slug}</strong> to its Projects list.</p>
      </div>
    )}

    {projectPhotos.length > 1 && (
      <div class="bottom-grid-section">
        <p class="bottom-grid-label">All images</p>
        <div class="bottom-grid">
          {projectPhotos.map((photo) => (
            <div class="bottom-grid-item">
              <LazyImage
                src={photo.data.image}
                alt={photo.data.alt || ''}
                cover={true}
                sizes="25vw"
              />
            </div>
          ))}
        </div>
      </div>
    )}

    <nav class="project-nav">
      <div class="project-nav-inner">
        {prevProject ? (
          <a href={`/projects/${prevProject.data.slug}`} class="project-nav-link prev">
            <span class="nav-dir">← Previous</span>
            <span class="nav-title">{prevProject.data.title}</span>
          </a>
        ) : <div />}

        <a href="/projects" class="project-nav-all">All Projects</a>

        {nextProject ? (
          <a href={`/projects/${nextProject.data.slug}`} class="project-nav-link next">
            <span class="nav-dir">Next →</span>
            <span class="nav-title">{nextProject.data.title}</span>
          </a>
        ) : <div />}
      </div>
    </nav>

  </div>
</Layout>

<style>
  .project-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px 80px;
  }

  .project-header {
    padding: 48px 0 40px;
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .project-description {
    font-family: var(--font);
    font-size: 15px;
    line-height: 1.75;
    color: #333;
  }

  .image-feed {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Portrait images constrained to 60% width */
  .feed-item {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .feed-item .li {
    width: 100%;
  }

  .feed-item.portrait .li {
    width: 60%;
  }

  .no-photos {
    padding: 60px 20px;
    text-align: center;
    color: #999;
    font-size: 13px;
    line-height: 2;
  }

  .bottom-grid-section {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .bottom-grid-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 16px;
  }

  .bottom-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
  }

  .bottom-grid-item {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .bottom-grid-item .li {
    width: 100%;
    height: 100%;
  }

  .project-nav {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid #e8e8e8;
  }

  .project-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  .project-nav-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .project-nav-link.next { text-align: right; }

  .nav-dir {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #999;
  }

  .nav-title {
    font-size: 13px;
    color: #111;
    transition: opacity 0.15s ease;
  }

  .project-nav-link:hover .nav-title { opacity: 0.6; }

  .project-nav-all {
    font-size: 12px;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: #999;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .project-nav-all:hover { color: #111; }

  @media (max-width: 700px) {
    .bottom-grid { grid-template-columns: repeat(3, 1fr); }
    .feed-item.portrait .li { width: 80%; }
    .project-nav-inner { grid-template-columns: 1fr; gap: 16px; }
    .project-nav-link.next { text-align: left; }
    .project-nav-all { order: -1; }
  }
</style>

<script>
  // Detect portrait images and constrain width
  document.querySelectorAll('.feed-item').forEach(item => {
    const img = item.querySelector('img');
    if (!img) return;

    const check = () => {
      if (img.naturalWidth > 0 && img.naturalHeight > img.naturalWidth) {
        item.classList.add('portrait');
      }
    };

    img.complete ? check() : img.addEventListener('load', check, { once: true });
  });
</script>
